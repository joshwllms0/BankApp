@using BankApp.Models 
@model List<Product>

    <h1>Product List</h1>

    @foreach (var product in Model) {
        <p>@product.Name</p>
        <p>@product.ID</p>
        <p>@product.Price</p>
        <p>@product.Quantity</p>

    <a asp-controller="Product" asp-action="Details" asp-route-id="@product.ID">View</a>
    <a asp-controller="Product" asp-action="Edit" asp-route-id="@product.ID">Edit</a>
    <a asp-controller="Product" asp-action="Delete" asp-route-id="@product.ID">Delete</a>
    }